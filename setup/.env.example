GH_EMAIL=""


# Agent (pi) Configs
# AGENT_MODEL: model pattern (e.g. "claude-sonnet-4:high", "openai/gpt-4o").
#   Supports "provider/id:thinking" shorthand (e.g. "openai/gpt-4o:high").
#   When using provider prefix in model, AGENT_PROVIDER can be empty.
# AGENT_KEY: API key for the provider (passed to pi as --api-key).
#   Also sets provider-specific env vars if needed (e.g. ANTHROPIC_API_KEY, OPENAI_API_KEY).
# AGENT_PROVIDER: provider name (e.g. "anthropic", "openai", "google", "openrouter").
#   Can be empty if provider is specified via model prefix (e.g. "openai/").
# AGENT_API: (reserved) custom API base URL — not yet supported directly.
AGENT_MODEL=""
AGENT_KEY=""
AGENT_API=""
AGENT_PROVIDER=""
